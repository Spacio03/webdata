# Bright Data — apply promo code "unlocked" at brightdata.com/cp/billing/overview
BRIGHTDATA_API_KEY=your_brightdata_api_key
BRIGHTDATA_SERP_ZONE=serp
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker

# AI/ML API (OpenAI-compatible)
AIML_API_KEY=your_aiml_api_key
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o

# Cognee memory
COGNEE_API_KEY=your_cognee_api_key

# TriggerWare
TRIGGERWARE_API_KEY=your_triggerware_key
TRIGGERWARE_INSTANCE_URL=https://yourname.triggerware.com/

# SendGrid email
SENDGRID_API_KEY=your_sendgrid_key
SENDGRID_FROM_EMAIL=outreach@yourdomain.com

# Slack alerts (optional — alerts are logged even without this)
SLACK_WEBHOOK_URL=

# App
DATABASE_URL=sqlite:///./mosaic.db
SECRET_KEY=change_me_in_production
FRONTEND_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_MODE=false

# Production mode — false = use live Bright Data/API pipeline
DEMO_MODE=false
ALERT_SCORE_THRESHOLD=70
